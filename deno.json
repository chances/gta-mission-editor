{
  "name": "gta-mission-editor",
  "version": "0.1.0",
  "description": "A web-based editor for creating 3D-era GTA mission scripts using Blockly",
  "tasks": {
    "dev": "deno run -A vite",
    "build": "deno run -A vite build"
  },
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^2.0.2",
    "@std/assert": "jsr:@std/assert@1",
    "blockly": "npm:blockly@^10.4.3",
    "vite": "npm:vite@^8.0.11"
  },
  "nodeModulesDir": "auto"
}
